OPENROUTER_API_KEY=

# Langfuse (paso 7, observabilidad LLM). Self-hosteado via docker-compose
# (docker compose up -d langfuse-web langfuse-worker postgres clickhouse redis minio).
# Las claves se generan en http://localhost:3000 tras el primer signup, no vienen
# seteadas por default: sin ellas, el SDK de Langfuse queda deshabilitado (no-op),
# asi que el resto del proyecto sigue funcionando sin trazas.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
